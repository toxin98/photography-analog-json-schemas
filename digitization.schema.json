{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Digitization",
  "type": "object",

  "oneOf": [
    {
      "properties": {
        "method": { "const": "camera" },
        "details": { "type": "string" }
      },
      "required": ["method", "details"],
      "additionalProperties": false
    },
    {
      "properties": {
        "method": { "const": "scanner" },
        "brand": { "type": "string" },
        "model": { "type": "string" }
      },
      "required": ["method", "brand", "model"],
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": {
            "brand": { "const": "Frontier" },
            "model": { "enum": ["SP-3000"] }
          }
        },
        {
          "properties": {
            "brand": { "const": "Hasselblad" },
            "model": { "enum": ["X5"] }
          }
        },
        {
          "properties": {
            "brand": { "const": "Noritsu" },
            "model": { "enum": ["HS-1800", "V-30"] }
          }
        }
      ]
    }
  ]
}