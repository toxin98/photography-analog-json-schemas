{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Metadata Schema",
  "type": "array",

  "items": {
    "type": "object",
    "required": ["id", "film", "camera", "note", "date", "development"],

    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[0-9]{4}$",
        "description": "Roll unique ID (e.g., 0001)"
      },

      "film": { "$ref": "./film.schema.json" },

      "camera": {
        "type": "string",
        "description": "Camera model",
        "enum": [
          "Nikon F2",
          "Pentax KX"
        ]
      },

      "note": {
        "type": "string"
      },

      "date": {
        "type": "object",
        "required": ["started", "finished"],
        "properties": {
          "started": { "type": "string", "format": "date" },
          "finished": { "type": "string", "format": "date" }
        },
        "additionalProperties": false
      },

      "development": {
        "type": "object",
        "required": ["lab", "process", "digitization"],
        "properties": {
          "lab": { "$ref": "./lab.schema.json" },
          "process": { "$ref": "./process.schema.json" },
          "digitization": { "$ref": "./digitization.schema.json" }
        },
        "additionalProperties": false
      }
    },

    "additionalProperties": false
  }
}